#!/bin/sh

echo "Running lint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "Lint failed. Push aborted."
  exit 1
fi

echo "Running format check..."
npm run format:check
if [ $? -ne 0 ]; then
  echo "Format check failed. Push aborted."
  exit 1
fi

echo "Running tests..."
npm test
if [ $? -ne 0 ]; then
  echo "Tests failed. Push aborted."
  exit 1
fi

echo "All checks passed."
